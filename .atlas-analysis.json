  "keyFeatures": [
    "Action recognition with 20+ state-of-the-art models (TSN, TSM, I3D, SlowFast, VideoMAE, etc.)",
    "Temporal action localization (BSN, BMN, TCANet)",
    "Spatio-temporal action detection on AVA and other benchmarks",
    "Skeleton-based action recognition (ST-GCN, PoseC3D, STGCN++)",
    "Video retrieval support (CLIP4Clip)",
    "Modular design for easy customization and extension",
    "Integration with MMEngine, MMCV, MMDetection, and MMPose",
    "Comprehensive dataset support including Kinetics, UCF101, HMDB51, AVA"
  ],
  "publicApiSurface": [
    "mmaction.apis.init_recognizer(config, checkpoint, device)",
    "mmaction.apis.inference_recognizer(model, video, test_pipeline)",
    "mmaction.apis.inference_skeleton(model, pose_results, img_shape, test_pipeline)",
    "mmaction.apis.detection_inference(det_config, det_checkpoint, frame_paths, ...)",
    "mmaction.apis.pose_inference(pose_config, pose_checkpoint, frame_paths, det_results, device)",
    "tools/train.py — model training script",
    "tools/test.py — model evaluation script",
    "tools/dist_train.sh — distributed training launcher",
    "tools/dist_test.sh — distributed evaluation launcher",
    "mmaction.models.recognizers — video recognition model classes",
    "mmaction.models.backbones — backbone network implementations",
    "mmaction.datasets — dataset classes and data pipelines",
    "mmaction.evaluation — metric and evaluation utilities"
  ]
